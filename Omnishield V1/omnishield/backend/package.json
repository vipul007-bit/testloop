{
  "name": "omnishield-backend",
  "version": "1.0.0",
  "private": true,
  "description": "OmniShield Backend — Node.js + Express + PostGIS surveillance API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "knex migrate:latest --knexfile src/db/knexfile.ts",
    "db:rollback": "knex migrate:rollback --knexfile src/db/knexfile.ts",
    "db:seed": "knex seed:run --knexfile src/db/knexfile.ts",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "h3-js": "^4.1.0",
    "knex": "^3.0.1",
    "pg": "^8.11.3",
    "ws": "^8.14.2",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.18",
    "@types/node": "^20.6.3",
    "@types/pg": "^8.10.3",
    "@types/ws": "^8.5.6",
    "@types/cors": "^2.8.14",
    "@types/morgan": "^1.9.6",
    "@types/compression": "^1.7.4",
    "@typescript-eslint/eslint-plugin": "^6.7.2",
    "@typescript-eslint/parser": "^6.7.2",
    "eslint": "^8.49.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
